    "express": "4.18.2",
    "jsonwebtoken": "9.0.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.10.6",
    "@types/supertest": "2.0.16",
    "prisma": "5.7.1",
    "supertest": "6.3.4",
    "tsx": "4.7.0",
    "typescript": "5.3.3",
    "vitest": "1.2.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-musl": "4.9.5"
